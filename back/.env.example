

#Condition de config pour la production
IS_PROD=false|true

#OPEN_AI SK
OPENAI_API_KEY=sk






VITE_HF_TOKEN=
VITE_HUGGINGFACE_TOKEN=

# Judilibre credentials
JUDI_CLIENT_ID=
JUDI_CLIENT_SECRET=
# Optionnel selon votre contrat PISTE
# JUDI_SCOPE=
# JUDI_AUDIENCE=
# Pour forcer un endpoint spécifique si différent chez vous
# JUDI_ENDPOINT=

# Veille juridique (module legal_watch — voir back/legal_watch/README.md)
# Clé API PISTE Judilibre (header KeyId) — alternative à JUDI_CLIENT_ID/SECRET,
# prioritaire si renseignée.
# JUDILIBRE_API_KEY=
# Endpoint Judilibre (défaut : https://api.piste.gouv.fr/cassation/judilibre/v1.0 ;
# sandbox : https://sandbox-api.piste.gouv.fr/cassation/judilibre/v1.0)
# JUDILIBRE_SEARCH_ENDPOINT=
# Modèle d'enrichissement (défaut : gpt-4o-mini)
# LEGAL_WATCH_ENRICH_MODEL=
# Si définie, les endpoints /legal-watch/* exigent le header x-internal-api-key
# (même valeur que dans backNode/.env)
# INTERNAL_API_KEY=

# Legifrance credentials
LEGI_CLIENT_ID=
LEGI_CLIENT_SECRET=

# .env
# Clés pour l'API Légifrance via PISTE
VITE_LEGI_CLIENT_ID=
VITE_LEGI_CLIENT_SECRET=

# Mise à jour du chemin pour pointer vers la clé dans le dossier du projet
GOOGLE_APPLICATION_CREDENTIALS="chemin vers : gen-lang-client...."

# Clé API pour le frontend Vite/React (analyse côté client, etc.)
VITE_OPENAI_API_KEY=""
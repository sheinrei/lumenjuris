// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

//==== ENUM ====

enum Role {
  USER
  ADMIN
  JURISTE // éditeur : import, validation IA, édition métadonnées
  LECTEUR // lecture seule
}

enum AuthProvider {
  GOOGLE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum TokenState {
  ACTIVE
  EXPIRED
  USED
}

enum EnvelopeStatus {
  DRAFT
  SENT
  PARTIALLY_SIGNED
  SIGNED
  DECLINED
  EXPIRED
}

// ─── CONTRATHÈQUE ───

enum ContractStatus {
  DRAFT // brouillon
  IN_NEGOTIATION // en négociation
  ACTIVE // signé / actif
  TACIT_RENEWAL // en tacite reconduction
  EXPIRED // échu
  TERMINATED // résilié
}

enum RenewalType {
  NONE
  TACIT // tacite reconduction
  EXPRESS // reconduction expresse
}

// État de validation "trust but verify" d'un champ extrait par IA.
enum FieldValidationStatus {
  AI_SUGGESTED // suggéré par l'IA, non encore validé
  HUMAN_VALIDATED // validé tel quel par un humain
  HUMAN_CORRECTED // corrigé par un humain
}

// Actions tracées dans le journal d'audit (RGPD : journalisation des accès).
enum AuditAction {
  IMPORT
  AI_EXTRACTION
  FIELD_VALIDATION
  METADATA_UPDATE
  AMENDMENT_ADDED
  VERSION_ADDED
  DOCUMENT_ACCESS
  EXPORT
  ARCHIVE
  DELETE
}

// ─── BIBLIOTHÈQUE DE CLAUSES ───

// Catégorie juridique d'une clause (regroupement dans la bibliothèque).
enum ClauseCategory {
  CONFIDENTIALITE
  RESPONSABILITE
  RESILIATION
  PROPRIETE_INTELLECTUELLE
  DONNEES_PERSONNELLES
  PAIEMENT
  DUREE_RENOUVELLEMENT
  FORCE_MAJEURE
  LITIGES
  GARANTIES
  NON_CONCURRENCE
  AUTRE
}

// Position de négociation d'une clause (logique de repli).
enum ClausePosition {
  IDEALE // position idéale (notre préférence)
  ACCEPTABLE // repli acceptable
  LIGNE_ROUGE // minimum non négociable
}

// ─── NÉGOCIATION ───

// Statut du workflow d'approbation d'un contrat.
enum ApprovalStatus {
  DRAFT // brouillon, pas encore soumis
  PENDING // soumis, en attente de décision
  APPROVED // approuvé
  REJECTED // rejeté
}

//==== CREATION DES MODELS ====

// --- UTILISATEUR ---

/// Compte utilisateur principal : identité, rôle, statut de vérification et bannissement.
/// Nœud central du schéma — toutes les entités de l'application sont rattachées à un User.
model User {
  idUser           Int     @id @default(autoincrement())
  role             Role    @default(USER)
  email            String  @unique
  nom              String?
  prenom           String?
  password         String?
  isVerified       Boolean @default(false)
  twoFactorEnabled Boolean @default(false)
  isBanned         Boolean @default(false)
  cgu              Boolean @default(false)
  stripeCustomerId String?

  //relation 
  tokens        Token[]
  events        Event[]
  authProviders AuthProviderAccount[]
  subscription  Subscription?
  enterprise    Enterprise?

  userCredit        UserCredit?
  preference        UserPreference?
  featureUsages     FeatureUsage[]
  documentCustom    DocumentCustom[]
  contractHistory   ContractHistory[]
  chatHistory       ChatHistory?
  userLlmUsage      UserLlmUsage[]
  userUpload        UserUpload?
  contractTemplates ContractTemplate[]
  signatureEnvelopes SignatureEnvelope[]

  // Contrathèque
  contracts         Contract[]
  contractFolders   Folder[]
  contractTags      Tag[]
  auditLogs         AuditLog[]
  clauses           Clause[]
  contractComments  ContractComment[]
}

// --- AUTH VIA PROVIDER ---

/// Compte tiers OAuth (Google). Stocke le providerId et l'avatar pour la connexion via provider externe.
model AuthProviderAccount {
  idAuthProvider Int          @id @default(autoincrement())
  providerId     String       @unique
  provider       AuthProvider
  avatarUrl      String?

  //relation
  userId Int
  user   User @relation(fields: [userId], references: [idUser])
}

/// Préférences UI et paramètres de compte de l'utilisateur, stockés en JSON pour rester flexibles.
model UserPreference {
  idUserPreference  Int   @id @default(autoincrement())
  preferenceUI      Json?
  accountParameters Json?

  //relation
  userId Int  @unique
  user   User @relation(fields: [userId], references: [idUser])
}

// --- ENTREPRISE ---

/// Entreprise liée à un utilisateur : infos juridiques (SIREN, NAF, statut) issues de l'API Sirene.
model Enterprise {
  idEnterprise        Int     @id @default(autoincrement())
  siren               String?
  codeNaf             String?
  intituleNaf         String?
  name                String?
  statusJuridiqueCode String?
  statusJuridique     String?
  idccSelections      Json?
  selectedIdccKey     String?

  //relation
  userId  Int      @unique
  user    User     @relation(fields: [userId], references: [idUser])
  address Address?
}

/// Adresse postale d'une entreprise. Séparée pour normaliser les données géographiques.
model Address {
  idAddress  Int     @id @default(autoincrement())
  address    String?
  codePostal String?
  pays       String? @default("FRANCE")

  //relation
  enterpriseId Int        @unique
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [idEnterprise], onDelete: Cascade, onUpdate: Cascade)
}

// --- SECURITE ---

/// Tokens sécurisés à usage unique : reset de mot de passe, vérification email, 2FA, etc.
/// Chaque token a un type, un statut (ACTIVE/EXPIRED/USED) et une date d'expiration.
model Token {
  idToken   Int        @id @default(autoincrement())
  token     String     @unique
  expiresAt DateTime
  type      String
  status    TokenState @default(ACTIVE)
  //relation
  userId    Int
  user      User       @relation(fields: [userId], references: [idUser])
}

// --- EVENTS ---

/// Événement applicatif lié à un utilisateur (ex : génération de document sur mesure).
/// Sert de déclencheur et de conteneur pour certains workflows asynchrones.
model Event {
  idEvent   Int      @id @default(autoincrement())
  type      String
  state     String
  expiresAt DateTime

  //relation
  userId         Int
  user           User            @relation(fields: [userId], references: [idUser])
  documentCustom DocumentCustom?
}

/// Document généré à la demande pour un utilisateur, rattaché à un Event.
/// Contient le contenu du template rendu (type + HTML/texte).
model DocumentCustom {
  idDocumentCustom Int    @id @default(autoincrement())
  type             String
  templateContent  String @db.Text

  //relation
  userId Int?
  user   User? @relation(fields: [userId], references: [idUser])

  eventId Int?   @unique
  event   Event? @relation(fields: [eventId], references: [idEvent])
}

/// Templates de documents globaux partagés (non liés à un utilisateur).
/// Base de génération commune pour les documents standards de la plateforme.
model DocumentTemplate {
  idDocument      Int    @id @default(autoincrement())
  type            String
  templateContent String @db.Text
}

// --- HISTORIQUE CHAT JURIDIQUE ---

/// Historique complet du chat juridique d'un utilisateur, stocké en JSON dans une LongText.
/// Une seule ligne par utilisateur, mise à jour à chaque nouvel échange.
model ChatHistory {
  idChatHistory Int    @id @default(autoincrement())
  conversations String @db.LongText

  userId Int  @unique
  user   User @relation(fields: [userId], references: [idUser], onDelete: Cascade)
}

// --- HISTORIQUE ANALYSES CONTRATS ---

/// Analyse de contrat sauvegardée : métadonnées claires (type, score, clauses) + snapshot chiffré.
/// Permet de rouvrir et comparer des analyses précédentes sans relancer l'IA.
model ContractHistory {
  idHistory         Int      @id @default(autoincrement())
  externalId        String   @unique
  fileName          String
  contractType      String?
  overallRiskScore  Float?
  wordCount         Int      @default(0)
  clausesCount      Int      @default(0)
  activePatchCount  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastOpenedAt      DateTime @default(now())
  // Snapshot completète chiffré : contenu contrat + clauses + contexte + patches
  encryptedSnapshot String   @db.LongText

  userId Int
  user   User @relation(fields: [userId], references: [idUser], onDelete: Cascade)

  @@index([userId])
}

// --- CREDIT ET PAYMENT ---

/// Crédits disponibles d'un utilisateur : `creditIncluded` vient du plan, `creditAdded` sont des bonus.
/// Décrémentés à chaque appel IA — épuisement (tous à 0) bloque les fonctionnalités payantes.
model UserCredit {
  idUserCredit   Int @id @default(autoincrement())
  creditIncluded Int
  creditAdded    Int

  //relation

  userId Int  @unique
  user   User @relation(fields: [userId], references: [idUser])
}

// --- SUIVI D'USAGE DES FONCTIONNALITÉS ---

/// Trace chaque appel à une fonctionnalité IA (feature, userId, date).
/// Alimente le tableau de bord monitoring : activité, top users, détection d'abus.
model FeatureUsage {
  id        Int      @id @default(autoincrement())
  feature   String
  userId    Int?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [idUser], onDelete: SetNull)

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
}

/// Abonnement d'un utilisateur à un plan tarifaire : statut, dates de début/expiration, référence Stripe.
model Subscription {
  idSubscription       Int                @id @default(autoincrement())
  status               SubscriptionStatus
  startAt              DateTime
  expiresAt            DateTime
  stripeSubscriptionId String?
  stripePriceId        String?

  //relation
  userId Int  @unique
  user   User @relation(fields: [userId], references: [idUser])

  planId Int
  plan   Plan @relation(fields: [planId], references: [idPlan])

  facture Facture[]
}

/// Définition d'un plan tarifaire : nom, prix, intervalle de facturation et crédits inclus.
model Plan {
  idPlan         Int    @id @default(autoincrement())
  name           String
  price          Int
  interval       String
  creditIncluded Int

  //relation
  subscription Subscription[]
}

/// Facture générée pour un abonnement, associée à une transaction Stripe.
/// `status` : "PAID" (paiement réussi) ou "FAILED" (tentative échouée, montant non encaissé).
model Facture {
  idFacture       Int      @id @default(autoincrement())
  price           Int
  stripeInvoiceId String
  status          String   @default("PAID")
  createdAt       DateTime @default(now())

  //relation

  subscriptionId Int
  subscription   Subscription @relation(fields: [subscriptionId], references: [idSubscription])
}

// --- RESSOURCE LLM ---

/// Référentiel des modèles LLM disponibles avec leurs prix d'entrée/sortie par million de tokens.
model Llm {
  idLlm            Int    @id @default(autoincrement())
  name             String @unique
  tokenPriceInput  Int
  tokenPriceOutput Int

  llmUsage     LlmUsage[]
  userLlmUsage UserLlmUsage[]
}


// --- MODELES DE CONTRATS (import + playbook + génération) ---

/// Template de contrat importé ou créé par un utilisateur : structure chiffrée + métadonnées.
/// Base de la génération IA personnalisée (avec playbook de règles et notes doctrinales associées).
model ContractTemplate {
  idTemplate         Int      @id @default(autoincrement())
  externalId         String   @unique
  name               String
  contractType       String?
  sourceFilename     String?
  sourceFilePath     String?
  encryptedStructure String   @db.LongText
  version            Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId         Int
  user           User              @relation(fields: [userId], references: [idUser], onDelete: Cascade)
  playbook       TemplatePlaybook?
  doctrinalNotes DoctrinalNote[]
  generationLogs GenerationLog[]

  @@index([userId])
}

/// Playbook de règles juridiques associé à un template (instructions, garde-fous de négociation).
/// Guide la génération IA et la logique de repli entre positions contractuelles.
model TemplatePlaybook {
  idPlaybook  Int      @id @default(autoincrement())
  rulesText   String   @db.LongText
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templateId Int              @unique
  template   ContractTemplate @relation(fields: [templateId], references: [idTemplate], onDelete: Cascade)
}

/// Note doctrinale rattachée à une clause d'un template : conseils d'interprétation et références juridiques.
model DoctrinalNote {
  idNote      Int      @id @default(autoincrement())
  externalId  String   @unique
  title       String
  content     String   @db.LongText
  clauseRef   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templateId Int
  template   ContractTemplate @relation(fields: [templateId], references: [idTemplate], onDelete: Cascade)

  @@index([templateId])
}

/// Log de chaque génération de contrat depuis un template : variables utilisées, tokens consommés et résultat chiffré.
model GenerationLog {
  idLog           Int      @id @default(autoincrement())
  externalId      String   @unique
  variables       Json
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  encryptedOutput String   @db.LongText
  createdAt       DateTime @default(now())

  templateId Int
  template   ContractTemplate @relation(fields: [templateId], references: [idTemplate], onDelete: Cascade)

  @@index([templateId])
}

// --- E-SIGNATURE : enveloppes de contrats à signer ---

/// Enveloppe de signature électronique entre un utilisateur et sa contrepartie.
/// Champs de signature chiffrés AES-256-GCM ; suivi complet du cycle de vie (DRAFT → SIGNED).
model SignatureEnvelope {
  idEnvelope           Int            @id @default(autoincrement())
  externalId           String         @unique
  documentName         String
  documentFilePath     String?
  numPages             Int            @default(1)
  // Token public unique pour la page de signature du cocontractant
  signingToken         String         @unique
  // Champs (zones de signature + signatures capturées) chiffrés AES-256-GCM
  encryptedFields      String         @db.LongText
  status               EnvelopeStatus @default(DRAFT)

  // Métadonnées signataires (clair pour permettre les filtres/recherche)
  selfName             String
  selfEmail            String
  counterpartyName     String
  counterpartyEmail    String

  // Suivi du cycle de vie
  sentAt               DateTime?
  selfSignedAt         DateTime?
  counterpartySignedAt DateTime?
  completedAt          DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  userId               Int
  user                 User           @relation(fields: [userId], references: [idUser], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}


// --- ASSETS UTILISATEUR (filigranes) ---
/// Images uploadées par l'utilisateur (ex : filigrane sur contrats exportés), stockées en JSON.
model UserUpload {
  idUserUpload    Int    @id @default(autoincrement())
  uploadedImages  Json

  userId Int  @unique
  user   User @relation(fields: [userId], references: [idUser], onDelete: Cascade)
}

/// Consommation LLM globale agrégée par modèle et par jour (upsert journalier).
/// Permet le suivi des coûts globaux de la plateforme dans le monitoring.
model LlmUsage {
  idLlmUsage   Int      @id @default(autoincrement())
  startAt      DateTime
  expiresAt    DateTime
  totalCostUsd Decimal  @db.Decimal(18, 6)
  tokenInput   Int
  tokenOutput  Int

  //relation
  llmId Int
  llm   Llm @relation(fields: [llmId], references: [idLlm])

  @@unique([llmId, startAt])
}

/// Consommation LLM par utilisateur, modèle et jour (upsert journalier).
/// Permet le suivi individuel des coûts et l'identification des top consommateurs.
model UserLlmUsage {
  idUserLlmUsage Int      @id @default(autoincrement())
  startAt        DateTime
  expiresAt      DateTime
  totalCostUsd   Decimal  @db.Decimal(18, 6)
  tokenInput     Int
  tokenOutput    Int

  //relation
  userId Int
  user   User @relation(fields: [userId], references: [idUser], onDelete: Cascade)

  llmId Int
  llm   Llm @relation(fields: [llmId], references: [idLlm])

  @@unique([llmId, startAt, userId])
  @@index([userId])
}

/// Contrat de la contrathèque : métadonnées claires (filtres/KPI) + PDF chiffré sur filesystem.
/// Nœud central du module — relié aux clauses, tags, dossiers, avenants et journal d'audit.
/// Principe : "l'IA suggère, le système garde-fou, l'humain décide."
model Contract {
  idContract       Int            @id @default(autoincrement())
  externalId       String         @unique
  title            String
  contractType     String?
  counterpartyName String? // cocontractant
  responsibleName  String? // responsable interne
  status           ContractStatus @default(DRAFT)

  // Dates clés
  signatureDate DateTime?
  effectiveDate DateTime? // date d'effet
  endDate       DateTime? // date d'échéance (null = sans date de fin)
  durationMonths Int?

  // Renouvellement — pilote la logique d'alerte (Chatel B2C vs art. 1215 B2B)
  renewalType      RenewalType @default(NONE)
  noticePeriodDays Int? // préavis en jours
  isB2C            Boolean     @default(false)

  // Financier
  amount   Decimal? @db.Decimal(18, 2)
  currency String?  @default("EUR")

  governingLaw String? // droit applicable

  // Document source (PDF chiffré sur filesystem — jamais le binaire en base)
  documentFilePath String?
  documentMimeType String?
  ocrText          String? @db.LongText // texte OCR (recherche full-text V1)

  // Workflow d'approbation (négociation)
  approvalStatus ApprovalStatus @default(DRAFT)
  approvalNote   String?        @db.Text // motif de la décision
  approvedById   Int? // utilisateur ayant approuvé/rejeté
  approvedAt     DateTime?

  // Archivage / RGPD
  isArchived     Boolean   @default(false)
  retentionUntil DateTime? // durée de conservation paramétrable

  // Liens (anticipation) vers briques existantes — nullable, non câblés en V1
  signatureEnvelopeExternalId String?
  templateExternalId          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId   Int
  user     User    @relation(fields: [userId], references: [idUser], onDelete: Cascade)
  folderId Int?
  folder   Folder? @relation(fields: [folderId], references: [idFolder], onDelete: SetNull)

  metadataFields ContractMetadataField[]
  amendments     Amendment[]
  versions       ContractVersion[]
  tags           ContractTag[]
  auditLogs      AuditLog[]
  comments       ContractComment[]

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@index([folderId])
}

/// Champ de métadonnée extrait par IA sur un contrat (montant, loi applicable, préavis…).
/// Implémente le "trust but verify" : score de confiance + statut de validation humaine (suggéré/validé/corrigé).
model ContractMetadataField {
  idField          Int                   @id @default(autoincrement())
  fieldKey         String // ex: "amount", "governing_law", "notice_period_days"
  value            String?               @db.Text
  confidenceScore  Float? // score IA 0..1
  validationStatus FieldValidationStatus @default(AI_SUGGESTED)
  validatedById    Int? // user ayant validé/corrigé
  validatedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contractId Int
  contract   Contract @relation(fields: [contractId], references: [idContract], onDelete: Cascade)

  @@unique([contractId, fieldKey])
  @@index([contractId])
}

/// Avenant lié à un contrat parent : modification contractuelle documentée avec date et résumé.
model Amendment {
  idAmendment      Int       @id @default(autoincrement())
  externalId       String    @unique
  title            String
  documentFilePath String?
  signatureDate    DateTime?
  effectiveDate    DateTime?
  summary          String?   @db.Text
  createdAt        DateTime  @default(now())

  parentContractId Int
  parentContract   Contract @relation(fields: [parentContractId], references: [idContract], onDelete: Cascade)

  @@index([parentContractId])
}

/// Version successive d'un contrat : historique documentaire pour comparer les évolutions du texte.
model ContractVersion {
  idVersion        Int      @id @default(autoincrement())
  versionNumber    Int      @default(1)
  documentFilePath String?
  contentText      String?  @db.LongText // instantané du texte du contrat (pour comparaison)
  note             String?  @db.Text
  createdById      Int?
  createdAt        DateTime @default(now())

  contractId Int
  contract   Contract @relation(fields: [contractId], references: [idContract], onDelete: Cascade)

  @@unique([contractId, versionNumber])
  @@index([contractId])
}

/// Label coloré créé par l'utilisateur pour organiser ses contrats (système de tags libre).
model Tag {
  idTag      Int      @id @default(autoincrement())
  externalId String   @unique
  label      String
  color      String   @default("#354F99")
  createdAt  DateTime @default(now())

  userId    Int
  user      User          @relation(fields: [userId], references: [idUser], onDelete: Cascade)
  contracts ContractTag[]

  @@unique([userId, label])
  @@index([userId])
}

/// Table de jonction many-to-many entre Contract et Tag.
model ContractTag {
  contractId Int
  tagId      Int

  contract Contract @relation(fields: [contractId], references: [idContract], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [idTag], onDelete: Cascade)

  @@id([contractId, tagId])
  @@index([tagId])
}

/// Dossier de classement des contrats avec arborescence parent/enfant (self-relation).
model Folder {
  idFolder   Int      @id @default(autoincrement())
  externalId String   @unique
  name       String
  createdAt  DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [idUser], onDelete: Cascade)

  parentId Int?
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [idFolder], onDelete: NoAction, onUpdate: NoAction)
  children Folder[] @relation("FolderTree")

  contracts Contract[]

  @@index([userId])
  @@index([parentId])
}

/// Journal d'audit RGPD : trace toutes les actions sensibles sur les contrats (import, accès, export…).
/// Immuable par design — chaque action crée une nouvelle ligne, jamais de mise à jour.
model AuditLog {
  idAudit       Int         @id @default(autoincrement())
  action        AuditAction
  entityType    String // "Contract", "Amendment", "ContractMetadataField"…
  entityId      String // externalId de l'entité concernée
  payloadBefore Json? // état avant
  payloadAfter  Json? // état après
  createdAt     DateTime    @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [idUser], onDelete: Cascade)

  contractId Int?
  contract   Contract? @relation(fields: [contractId], references: [idContract], onDelete: Cascade)

  @@index([userId])
  @@index([contractId])
  @@index([entityType, entityId])
}

/// Clause réutilisable de la bibliothèque juridique : catégorisée par type et position de négociation.
/// Stocke trois positions (idéale / acceptable / ligne rouge) pour guider la stratégie contractuelle.
model Clause {
  idClause   Int            @id @default(autoincrement())
  externalId String         @unique
  title      String
  category   ClauseCategory @default(AUTRE)
  position   ClausePosition @default(IDEALE)
  body       String         @db.LongText // texte de la clause
  notes      String?        @db.Text // conseils d'usage / commentaire juridique
  language   String         @default("fr")
  tags       String? // tags libres séparés par virgule
  isApproved Boolean        @default(false) // validée par un juriste
  usageCount Int            @default(0) // nombre d'insertions (popularité)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [idUser], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

/// Commentaire collaboratif ancré sur un contrat, avec fil de discussion et statut "résolu".
model ContractComment {
  idComment  Int      @id @default(autoincrement())
  externalId String   @unique
  body       String   @db.Text
  resolved   Boolean  @default(false) // marqué comme traité
  createdAt  DateTime @default(now())

  contractId Int
  contract   Contract @relation(fields: [contractId], references: [idContract], onDelete: Cascade)
  userId     Int
  user       User     @relation(fields: [userId], references: [idUser], onDelete: Cascade)

  @@index([contractId])
  @@index([userId])
}

// ════════════════════════════════════════════════════════════════════════════
// MODULE NÉGOCIATION (isolé — couplé au Contrat par ID, sans relation Prisma)
// Tous les liens vers User/Contract sont des scalaires (ownerUserId, createdById,
// contractExternalId) : aucun modèle existant n'est modifié.
// ════════════════════════════════════════════════════════════════════════════

enum NegotiationStatus {
  DRAFT // brouillon
  IN_NEGOTIATION // en négociation active
  VALIDATED // version finale validée (prête pour signature)
  BLOCKED // bloquée
  CLOSED // close / abandonnée
}

enum ParticipantSide {
  INTERNAL // partie interne (nous)
  EXTERNAL // contrepartie
}

enum ParticipantRole {
  READER // lecture seule
  COMMENTER // peut commenter
  PROPOSER // peut proposer des redlines
  VALIDATOR // peut valider la version finale
}

enum ProposalStatus {
  PROPOSED // proposée
  ACCEPTED // acceptée
  REJECTED // rejetée
  COUNTERED // contre-proposée
}

enum CommentVisibility {
  INTERNAL // visible côté interne uniquement
  EXTERNAL // visible par la contrepartie
}

enum NegotiationAuditAction {
  SESSION_CREATED
  STATUS_CHANGED
  VERSION_CREATED
  PROPOSAL_CREATED
  PROPOSAL_STATUS_CHANGED
  COMMENT_ADDED
  PARTICIPANT_ADDED
  PARTICIPANT_REMOVED
  GUEST_INVITED
  GUEST_REVOKED
  VALIDATED
  ABORTED
}

/// Session de négociation d'un contrat : orchestre le workflow entre partie interne et contrepartie.
/// Agrège les versions, propositions de clauses, commentaires, participants et journal d'audit.
model NegotiationSession {
  idNegotiation      Int               @id @default(autoincrement())
  externalId         String            @unique
  contractExternalId String // couplage par ID (isolation, pas de FK)
  title              String
  status             NegotiationStatus @default(DRAFT)
  ownerUserId        Int // créateur interne (scalaire, pas de FK)
  finalVersionId     Int? // version validée → consommée par la signature
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  versions      NegotiationVersion[]
  proposals     ClauseProposal[]
  comments      NegotiationComment[]
  participants  NegotiationParticipant[]
  guestAccesses GuestAccess[]
  auditLogs     NegotiationAudit[]

  @@index([contractExternalId])
  @@index([ownerUserId])
}

/// Version immuable du texte contractuel pendant la négociation. Base de comparaison entre rounds.
model NegotiationVersion {
  idVersion      Int      @id @default(autoincrement())
  externalId     String   @unique
  versionNumber  Int      @default(1)
  label          String?
  contentText    String   @db.LongText // texte de la version (immuable)
  structuredJson Json? // structure clause-par-clause (optionnel)
  createdById    Int
  createdAt      DateTime @default(now())

  negotiationId Int
  negotiation   NegotiationSession @relation(fields: [negotiationId], references: [idNegotiation], onDelete: Cascade)

  @@unique([negotiationId, versionNumber])
  @@index([negotiationId])
}

/// Proposition de modification d'une clause pendant la négociation.
/// Suit le statut de la proposition : proposée / acceptée / rejetée / contre-proposée.
model ClauseProposal {
  idProposal          Int            @id @default(autoincrement())
  externalId          String         @unique
  clauseRef           String // identifiant de clause (ex. "art-3" ou titre)
  originalText        String?        @db.Text
  proposedText        String         @db.Text
  type                String         @default("PROPOSED") // PROPOSED | COUNTER
  status              ProposalStatus @default(PROPOSED)
  authorParticipantId Int?
  createdById         Int?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  negotiationId Int
  negotiation   NegotiationSession @relation(fields: [negotiationId], references: [idNegotiation], onDelete: Cascade)

  @@index([negotiationId])
  @@index([clauseRef])
}

/// Commentaire ancré sur le texte d'une version de négociation (avec surlignement optionnel).
/// Peut être interne (équipe) ou visible par la contrepartie, et marqué comme résolu.
model NegotiationComment {
  idComment           Int               @id @default(autoincrement())
  externalId          String            @unique
  clauseRef           String? // ancrage clause (null = commentaire général)
  body                String            @db.Text
  visibility          CommentVisibility @default(INTERNAL)
  parentCommentId     Int? // fil de discussion
  authorParticipantId Int?
  createdById         Int?
  // Ancrage de l'annotation sur le texte du contrat (surlignement)
  anchorStart         Int? // offset caractère de début dans contentText
  anchorEnd           Int? // offset caractère de fin
  quote               String?           @db.Text // texte surligné (affichage/repérage)
  proposedText        String?           @db.Text // reformulation proposée (optionnel)
  resolved            Boolean           @default(false)
  createdAt           DateTime          @default(now())

  negotiationId Int
  negotiation   NegotiationSession @relation(fields: [negotiationId], references: [idNegotiation], onDelete: Cascade)

  @@index([negotiationId])
  @@index([clauseRef])
}

/// Participant à une session de négociation (interne ou externe).
/// Définit le côté (INTERNAL/EXTERNAL) et les droits (lecture / commentaire / proposition / validation).
model NegotiationParticipant {
  idParticipant Int             @id @default(autoincrement())
  externalId    String          @unique
  side          ParticipantSide @default(INTERNAL)
  role          ParticipantRole @default(COMMENTER)
  userId        Int? // interne (scalaire, pas de FK)
  name          String?
  email         String?
  createdAt     DateTime        @default(now())

  negotiationId Int
  negotiation   NegotiationSession @relation(fields: [negotiationId], references: [idNegotiation], onDelete: Cascade)

  @@index([negotiationId])
}

/// Accès invité temporaire à une négociation via un token secret, limité dans le temps et révocable.
model GuestAccess {
  idGuest       Int       @id @default(autoincrement())
  externalId    String    @unique
  token         String    @unique // secret du lien invité
  participantId Int?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  negotiationId Int
  negotiation   NegotiationSession @relation(fields: [negotiationId], references: [idNegotiation], onDelete: Cascade)

  @@index([negotiationId])
  @@index([token])
}

// ════════════════════════════════════════════════════════════════════════════
// MODULE VEILLE JURIDIQUE (isolé — couplé à User/Contract par ID scalaire,
// sans relation Prisma : aucun modèle existant n'est modifié).
//
// Pipeline : ingestion Judilibre (via microservice Python, stateless) →
// enrichissement LLM → matching par type de modèle → alertes + digest.
// Principe : la veille détecte et priorise, elle ne constitue jamais un avis
// juridique — le juriste reste le décideur.
// ════════════════════════════════════════════════════════════════════════════

// Cycle de vie d'un item de veille.
enum LegalWatchItemStatus {
  INGESTED // récupéré, en attente d'enrichissement
  ENRICHED // enrichi par le LLM, en attente de publication
  PUBLISHED // publié (digest + alertes générées)
  DISCARDED // hors périmètre de la taxonomie
  ERROR // enrichissement en échec (après retry)
}

// Niveau d'impact estimé par le LLM (à valider par un professionnel du droit).
enum LegalWatchImpact {
  HAUT // revirement ou précision nouvelle affectant rédaction/validité
  MOYEN // confirmation avec application notable
  FAIBLE // le reste
}

enum LegalWatchAlertStatus {
  UNREAD
  READ
  DISMISSED
}

// Source de veille ("judilibre", plus tard "legifrance").
model LegalWatchSource {
  idSource  Int       @id @default(autoincrement())
  name      String    @unique
  isActive  Boolean   @default(true)
  lastRunAt DateTime? // borne de la fenêtre glissante d'ingestion

  items LegalWatchItem[]
}

// Décision/texte ingéré puis enrichi par le LLM.
model LegalWatchItem {
  idItem      Int    @id @default(autoincrement())
  externalId  String @unique // identifiant public (uuid)
  providerId  String // ID de la décision chez la source (ex. ID Judilibre)
  contentHash String @unique // SHA-256 du texte intégral — dédup entre runs

  title        String
  jurisdiction String? // chambre (soc, com, civ1…)
  decisionDate DateTime?
  sourceUrl    String // lien vers la décision officielle
  rawText      String    @db.LongText

  // Champs remplis par l'enrichissement LLM :
  summary     String?           @db.Text // 2-3 phrases en langage clair
  legalDomain String? // ex. "droit_travail_contrats_precaires" | "hors_perimetre"
  concepts    Json? // concepts de la taxonomie détectés (liste fermée)
  impactLevel LegalWatchImpact?
  isEvolution Boolean? // évolution vs confirmation d'une position établie
  confidence  Float? // confiance déclarée par le LLM (0..1)
  enrichedAt  DateTime?
  enrichError String?           @db.Text // dernière erreur d'enrichissement

  status    LegalWatchItemStatus @default(INGESTED)
  createdAt DateTime             @default(now())

  sourceId Int
  source   LegalWatchSource @relation(fields: [sourceId], references: [idSource])
  alerts   LegalWatchAlert[]

  @@unique([sourceId, providerId]) // idempotence : une décision par source
  @@index([status])
  @@index([decisionDate])
  @@index([legalDomain])
}

// Taxonomie : concept juridique surveillé → types de modèles concernés.
model LegalConceptMapping {
  idConcept     Int     @id @default(autoincrement())
  concept       String  @unique // ex. "delai_de_carence"
  label         String // libellé lisible : "Délai de carence"
  legalDomain   String // ex. "droit_travail_contrats_precaires"
  keywords      Json // mots-clés/expressions (filtrage + prompt LLM)
  contractTypes Json // clés de modèles concernés, ex. ["cdd_accroissement"]
  isActive      Boolean @default(true) // thème surveillé (paramétrable par l'utilisateur)
}

// Alerte ciblée : un item de veille touche des contrats du portefeuille d'un user.
model LegalWatchAlert {
  idAlert     Int                   @id @default(autoincrement())
  externalId  String                @unique
  userId      Int // scalaire (pas de FK) — modèle multi-tenant par utilisateur
  contractIds Json // externalIds des contrats concernés
  status      LegalWatchAlertStatus @default(UNREAD)
  createdAt   DateTime              @default(now())

  itemId Int
  item   LegalWatchItem @relation(fields: [itemId], references: [idItem], onDelete: Cascade)

  @@unique([itemId, userId]) // idempotence : pas de double alerte
  @@index([userId, status])
}

model NegotiationAudit {
  idAudit       Int                    @id @default(autoincrement())
  action        NegotiationAuditAction
  actorUserId   Int?
  actorLabel    String? // nom affiché (interne ou invité)
  versionId     Int?
  payload       Json?
  createdAt     DateTime               @default(now())

  negotiationId Int
  negotiation   NegotiationSession @relation(fields: [negotiationId], references: [idNegotiation], onDelete: Cascade)

  @@index([negotiationId])
}
